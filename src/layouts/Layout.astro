---
import "../styles/global.css";
import release from "../data/release.json";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SpinApp — AI-enabled Laravel local dev",
  description = "Desktop app for Laravel developers. Spin up Docker environments with a built-in MCP server — connect Cursor, Claude, or any MCP assistant to run artisan, npm, SQL, and logs in your containers.",
} = Astro.props;

const site = Astro.site ?? new URL("https://spinapp.site");
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImageURL = new URL("/og-image.png", site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#3b0764" />
    <link rel="icon" type="image/svg+xml" href="/spinapp-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
  </head>
  <body class="mesh-bg text-white antialiased" data-track-file={release.filename}>
    <slot />
    <script>
      import { trackDownload as trackDownloadCount } from "../lib/download-counter.ts";

      const defaultFile = document.body.dataset.trackFile ?? "";

      document.addEventListener("click", (event) => {
        const link = event.target.closest("[data-track-download]");
        if (!link) return;

        const file = link.getAttribute("data-track-download") || defaultFile;
        if (!file) return;

        trackDownloadCount(file).then((data) => {
          if (data) {
            document.dispatchEvent(
              new CustomEvent("spinapp:download-tracked", { detail: data }),
            );
          }
        });
      });
    </script>
  </body>
</html>
