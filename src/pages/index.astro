        {steps.map((step, i) => (
          <div class="relative text-center md:text-left">
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-8 left-[calc(100%-1rem)] w-[calc(100%-4rem)] h-px bg-gradient-to-r from-spin-400/40 to-transparent" aria-hidden="true"></div>
