---
import Layout from "../layouts/Layout.astro";
import release from "../data/release.json";

const features = [
  {
    icon: "scan",
    title: "Smart project scanning",
    description:
      "Drop in a Laravel or JavaScript project folder. SpinApp detects your stack — PHP version, Node, database drivers, queue workers — and configures everything automatically.",
  },
  {
    icon: "docker",
    title: "Docker without the YAML",
    description:
      "No hand-written Compose files. SpinApp builds and manages containers for your app, database, cache, queue, and web server — named, isolated, and reproducible.",
  },
  {
    icon: "db",
    title: "Database provisioning",
    description:
      "PostgreSQL, MySQL, MariaDB, or SQLite — pick your engine and SpinApp creates the database, runs migrations, and wires up credentials for you.",
  },
  {
    icon: "dashboard",
    title: "One-click environment control",
    description:
      "Start, stop, and restart your entire stack from a clean dashboard. Every service status at a glance, no terminal juggling required.",
  },
  {
    icon: "terminal",
    title: "Built-in console",
    description:
      "Run artisan, npm, and SQL queries directly against your containers. No context-switching between terminals and Docker exec.",
  },
  {
    icon: "profile",
    title: "HTTP & SQL profiling",
    description:
      "Built-in SPX profiling for Laravel with SQL query logging. Find bottlenecks before they reach production.",
  },
  {
    icon: "expose",
    title: "Cloudflare tunnel exposure",
    description:
      "Share your local environment with teammates or clients via a secure Cloudflare tunnel — no ngrok config needed.",
  },
  {
    icon: "ide",
    title: "IDE integration",
    description:
      "Open your project in VS Code, Cursor, or PhpStorm with one click. Local *.local domains managed in /etc/hosts automatically.",
  },
];

const steps = [
  {
    num: "01",
    title: "Pick your project",
    description: "Select any Laravel or JavaScript project folder on your machine.",
  },
  {
    num: "02",
    title: "Configure once",
    description: "Walk through the setup wizard — PHP, Node, database, cache, queue, web server.",
  },
  {
    num: "03",
    title: "Spin it up",
    description: "Hit start. Containers launch, the database provisions, and you're developing.",
  },
];

const stacks = [
  "Laravel",
  "Vue / React",
  "PostgreSQL",
  "MySQL",
  "Redis",
  "RabbitMQ",
  "Docker",
  "Colima",
];
---

<Layout>
  <div class="grid-pattern fixed inset-0 pointer-events-none opacity-50" aria-hidden="true"></div>

  <!-- Ambient orbs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-spin-500/20 blur-3xl animate-pulse-glow"></div>
    <div class="absolute top-1/3 -right-24 w-80 h-80 rounded-full bg-spin-400/15 blur-3xl animate-pulse-glow" style="animation-delay: 2s"></div>
    <div class="absolute -bottom-24 left-1/3 w-72 h-72 rounded-full bg-spin-600/20 blur-3xl animate-pulse-glow" style="animation-delay: 1s"></div>
  </div>

  <!-- Nav -->
  <header class="relative z-10">
    <nav class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <img src="/spinapp-icon.svg" alt="" class="w-10 h-10 rounded-[22%] shadow-lg shadow-spin-500/30 group-hover:scale-105 transition-transform" width="40" height="40" />
        <span class="text-xl font-semibold tracking-tight">SpinApp</span>
      </a>
      <div class="flex items-center gap-4">
        <a href="#features" class="hidden sm:inline text-sm text-white/60 hover:text-white transition-colors">Features</a>
        <a href="#how-it-works" class="hidden sm:inline text-sm text-white/60 hover:text-white transition-colors">How it works</a>
        <a
          href={release.downloadUrl}
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-white text-spin-900 hover:bg-spin-100 transition-colors shadow-lg shadow-spin-500/20"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          Download
        </a>
      </div>
    </nav>
  </header>

  <!-- Hero -->
  <section class="relative z-10 max-w-6xl mx-auto px-6 pt-16 pb-24 sm:pt-24 sm:pb-32">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass text-xs font-medium text-spin-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          v{release.version} — macOS ready
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6">
          <span class="text-gradient">Local dev environments,</span>
          <br />
          spun up in seconds
        </h1>

        <p class="text-lg sm:text-xl text-white/65 max-w-xl mx-auto lg:mx-0 leading-relaxed mb-10">
          Pick a project folder. SpinApp scans your Laravel or JavaScript stack, creates Docker containers,
          provisions the database, and runs your environment — no hand-written Compose files.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <a
            href={release.downloadUrl}
            class="group inline-flex items-center gap-3 px-8 py-4 rounded-2xl font-semibold text-spin-950 bg-gradient-to-r from-white via-spin-100 to-spin-200 hover:from-spin-50 hover:to-white transition-all shadow-xl shadow-spin-500/25 hover:shadow-spin-400/40 hover:scale-[1.02] active:scale-[0.98]"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            Download for macOS
            <span class="text-xs font-normal text-spin-700/70 bg-spin-200/50 px-2 py-0.5 rounded-full">v{release.version}</span>
          </a>

          <div class="inline-flex items-center gap-2 px-5 py-4 rounded-2xl glass text-sm text-white/50 cursor-not-allowed select-none">
            <svg class="w-5 h-5 opacity-40" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.5A2.5 2.5 0 0 1 5.5 3h13A2.5 2.5 0 0 1 21 5.5v13a2.5 2.5 0 0 1-2.5 2.5h-13A2.5 2.5 0 0 1 3 18.5v-13zM5.5 5a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5h-13z"/><path d="M7 8h10v1.5H7V8zm0 3h10v1.5H7V11zm0 3h7v1.5H7V14z"/></svg>
            Windows
            <span class="text-xs font-medium text-spin-300/80 bg-spin-800/50 px-2 py-0.5 rounded-full border border-spin-600/30">Coming soon</span>
          </div>
        </div>

        <p class="mt-5 text-xs text-white/35">
          Requires macOS 12+ · Apple Silicon &amp; Intel · Docker Desktop or Colima
        </p>
      </div>

      <div class="flex-1 flex justify-center lg:justify-end">
        <div class="relative animate-float">
          <div class="absolute inset-0 rounded-3xl bg-spin-400/20 blur-3xl scale-110"></div>
          <div class="relative glass-strong rounded-3xl p-8 sm:p-10 shadow-2xl shadow-spin-900/50">
            <img src="/spinapp-icon.svg" alt="SpinApp" class="w-48 h-48 sm:w-56 sm:h-56 rounded-[22%] shadow-2xl shadow-spin-500/40" width="224" height="224" />
            <div class="mt-6 flex flex-wrap gap-2 justify-center">
              {stacks.map((s) => (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/8 text-white/70 border border-white/10">{s}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section class="relative z-10 border-y border-white/8 bg-white/[0.02]">
    <div class="max-w-6xl mx-auto px-6 py-8 grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-gradient">0 YAML</div>
        <div class="text-sm text-white/45 mt-1">Compose files to write</div>
      </div>
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-gradient">4 DBs</div>
        <div class="text-sm text-white/45 mt-1">PostgreSQL, MySQL, MariaDB, SQLite</div>
      </div>
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-gradient">1 click</div>
        <div class="text-sm text-white/45 mt-1">Start your entire stack</div>
      </div>
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-gradient">Native</div>
        <div class="text-sm text-white/45 mt-1">Tauri desktop app</div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="relative z-10 max-w-6xl mx-auto px-6 py-24 sm:py-32">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
        Everything you need to <span class="text-gradient">develop locally</span>
      </h2>
      <p class="text-white/55 max-w-2xl mx-auto text-lg">
        SpinApp replaces the patchwork of Docker Compose, database scripts, hosts files, and tunnel tools
        with one polished desktop experience.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((f) => (
        <div class="group glass rounded-2xl p-6 hover:bg-white/[0.09] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="w-10 h-10 rounded-xl bg-spin-500/20 flex items-center justify-center mb-4 group-hover:bg-spin-500/30 transition-colors">
            {f.icon === "scan" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
            )}
            {f.icon === "docker" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            )}
            {f.icon === "db" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75"/></svg>
            )}
            {f.icon === "dashboard" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
            )}
            {f.icon === "terminal" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>
            )}
            {f.icon === "profile" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
            )}
            {f.icon === "expose" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
            )}
            {f.icon === "ide" && (
              <svg class="w-5 h-5 text-spin-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
            )}
          </div>
          <h3 class="font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-white/50 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="relative z-10 border-t border-white/8">
    <div class="max-w-6xl mx-auto px-6 py-24 sm:py-32">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
          From folder to <span class="text-gradient">running app</span> in three steps
        </h2>
        <p class="text-white/55 max-w-xl mx-auto text-lg">
          No DevOps degree required. SpinApp handles the infrastructure so you can focus on code.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {steps.map((step, i) => (
          <div class="relative text-center md:text-left">
            {i < steps.length - 1 && (
              <div class="hidden md:block absolute top-8 left-[calc(100%-1rem)] w-[calc(100%-4rem)] h-px bg-gradient-to-r from-spin-400/40 to-transparent" aria-hidden="true"></div>
            )}
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl glass-strong text-2xl font-bold text-spin-300 mb-5">
              {step.num}
            </div>
            <h3 class="text-xl font-semibold mb-2">{step.title}</h3>
            <p class="text-white/50 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Deep dive -->
  <section class="relative z-10 max-w-6xl mx-auto px-6 pb-24 sm:pb-32">
    <div class="glass-strong rounded-3xl p-8 sm:p-12 lg:p-16 overflow-hidden relative">
      <div class="absolute top-0 right-0 w-64 h-64 bg-spin-500/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>

      <div class="relative grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">
            Built for developers who ship
          </h2>
          <p class="text-white/55 leading-relaxed mb-6">
            SpinApp is a native desktop app built with Tauri and Rust — fast, lightweight, and private.
            Your projects stay on your machine. Docker containers are namespaced per project.
            Redis, Valkey, RabbitMQ — all configurable from the setup wizard.
          </p>
          <ul class="space-y-3 text-sm text-white/60">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Auto/manual setup wizard for PHP, Node, database, cache &amp; queue
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Works with Docker Desktop or Colima — SpinApp can help you get started
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Local *.local domains with automatic /etc/hosts management
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              SPX profiling patches applied safely with automatic backups
            </li>
          </ul>
        </div>

        <div class="rounded-2xl bg-spin-950/60 border border-white/8 p-6 font-mono text-sm leading-relaxed overflow-hidden">
          <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/8">
            <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/80"></div>
            <span class="ml-2 text-white/30 text-xs">spinapp console</span>
          </div>
          <div class="text-spin-300/80">
            <span class="text-emerald-400">$</span> spinapp start my-laravel-app<br />
            <span class="text-white/40">→ Scanning project… Laravel 11 detected</span><br />
            <span class="text-white/40">→ Starting spinapp-my-laravel-app-app</span><br />
            <span class="text-white/40">→ Starting spinapp-my-laravel-app-db</span><br />
            <span class="text-white/40">→ Provisioning database… done</span><br />
            <span class="text-emerald-400">✓</span> <span class="text-white/70">https://my-laravel-app.local</span><br />
            <br />
            <span class="text-emerald-400">$</span> artisan migrate --seed<br />
            <span class="text-white/40">→ Running in container…</span><br />
            <span class="text-emerald-400">✓</span> <span class="text-white/70">Migration complete</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 border-t border-white/8">
    <div class="max-w-3xl mx-auto px-6 py-24 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
        Ready to spin up?
      </h2>
      <p class="text-white/55 text-lg mb-10">
        Download SpinApp for macOS and go from zero to running environment in minutes.
      </p>
      <a
        href={release.downloadUrl}
        class="inline-flex items-center gap-3 px-10 py-5 rounded-2xl font-semibold text-lg text-spin-950 bg-gradient-to-r from-white via-spin-100 to-spin-200 hover:from-spin-50 hover:to-white transition-all shadow-xl shadow-spin-500/25 hover:scale-[1.02] active:scale-[0.98]"
      >
